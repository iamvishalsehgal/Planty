{
  "name": "planty",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --reload --port 3001",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && pip3 install -r requirements.txt",
    "start": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
